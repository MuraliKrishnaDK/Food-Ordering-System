{
  "buildCommand": "cd xwiggy-app && npm install --legacy-peer-deps && npm run build -- --prod",
  "outputDirectory": "xwiggy-app/dist/xwiggy-app",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "build": {
    "env": {
      "NODE_OPTIONS": "--openssl-legacy-provider"
    }
  }
}
